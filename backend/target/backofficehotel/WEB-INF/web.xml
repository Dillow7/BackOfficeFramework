<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee" version="3.1">

    <!-- Custom initializer pour scanner les contrôleurs -->
    <!-- Le listener est auto-découvert via @WebListener dans AppInitializer -->
    
	<servlet>
		<servlet-name>FrontServlet</servlet-name>
		<servlet-class>mg.framework.FrontServlet</servlet-class>
	</servlet>

	<filter>
		<filter-name>NoCacheFilter</filter-name>
		<filter-class>com.hotel.backoffice.NoCacheFilter</filter-class>
	</filter>

	<filter-mapping>
		<filter-name>NoCacheFilter</filter-name>
		<url-pattern>/css/*</url-pattern>
	</filter-mapping>

	<servlet-mapping>
		<servlet-name>FrontServlet</servlet-name>
		<url-pattern>/</url-pattern>
	</servlet-mapping>

</web-app>
